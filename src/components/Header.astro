---
// さきほど作った検索モーダルをインポートします
import SearchModal from './SearchModal.astro';
---
<header class="header">
  <div class="header-inner">
    <a href="/" class="site-title">Hacca's engineering memo</a>
    
    {/* 検索ボタン（SVGで虫眼鏡アイコンを描画） */}
    <button id="open-search" class="search-button" aria-label="検索">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </button>
  </div>
  
  {/* ここに見えない状態でモーダルを配置しておきます */}
  <SearchModal />
</header>

<style>
  .header {
    background-color: var(--color-main);
    padding: 1.5rem 0;
  }
  
  .header-inner {
    width: 80%;
    max-width: 1000px;
    margin: 0 auto;
    /* Flexboxを使って、タイトルを左、ボタンを右に配置します */
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-title {
    color: #ffffff;
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
  }

  /* --- 検索ボタンのスタイル --- */
  .search-button {
    background: none;
    border: none;
    color: #ffffff; /* 瑠璃色の背景に映えるように白 */
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background-color 0.2s;
  }

  /* ホバー時に少し背景色をつけてボタンっぽくする */
  .search-button:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
</style>

<script>
  // JavaScriptで「検索ボタン」を押したときの処理を書きます
  const openBtn = document.getElementById('open-search');
  // SearchModal.astro で作った dialog タグを取得
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement;

  if (openBtn && dialog) {
    openBtn.addEventListener('click', () => {
      // showModal() は、背景を暗くして最前面に開くための専用の魔法のメソッドです
      dialog.showModal();
    });
  }
</script>