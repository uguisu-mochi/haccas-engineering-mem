---
// astro-pagefind が用意してくれている検索UIコンポーネントを読み込みます
import Search from "astro-pagefind/components/Search";
---

{/* モーダル本体（HTMLのdialogタグを使用） */}
<dialog id="search-dialog" class="search-modal">
  <div class="modal-content">
    
    <div class="modal-header">
      <span class="modal-title">記事を検索</span>
      <button id="close-search" class="close-button" aria-label="閉じる">&times;</button>
    </div>
    
    <div class="search-container">
      {/* Pagefindの検索窓と結果一覧がここに自動生成されます */}
      <Search id="search" className="pagefind-ui" uiOptions={{ showImages: false }} />
    </div>
    
  </div>
</dialog>

<style>
  /* --- モーダル全体のスタイル --- */
  .search-modal {
    border: none;
    border-radius: 12px;
    padding: 0;
    width: 90%;
    max-width: 600px;
    background-color: var(--color-base);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  /* モーダルの背景（backdrop）を暗く、少しぼかす */
  .search-modal::backdrop {
    background-color: rgba(26, 32, 44, 0.6); /* ダークスレートの半透明 */
    backdrop-filter: blur(2px);
  }

  .modal-content {
    display: flex;
    flex-direction: column;
    max-height: 80vh; /* 画面の高さを超えないように制限 */
  }

  /* --- ヘッダー部分（タイトルと閉じるボタン） --- */
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .modal-title {
    font-weight: bold;
    color: var(--color-text-main);
  }

  .close-button {
    background: none;
    border: none;
    font-size: 1.8rem;
    cursor: pointer;
    color: var(--color-text-sub);
    line-height: 1;
    transition: color 0.2s;
  }

  .close-button:hover {
    color: var(--color-main);
  }

  /* --- 検索UIが入るコンテナ --- */
  .search-container {
    padding: 1.5rem;
    overflow-y: auto; /* 検索結果が増えたらスクロール可能に */
  }

  /* --- Pagefindの標準デザインをサイトカラーに合わせて微調整 --- */
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--color-main);
    --pagefind-ui-text: var(--color-text-main);
    --pagefind-ui-background: var(--color-base);
    --pagefind-ui-border: #e2e8f0;
    --pagefind-ui-font: 'Inter', sans-serif;
  }
</style>

<script>
  // JavaScriptでモーダルを閉じる処理を書きます
  // (開く処理は次のStepでHeaderに書きます)
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement;
  const closeBtn = document.getElementById('close-search');

  // 1. 「×」ボタンをクリックした時
  if (closeBtn && dialog) {
    closeBtn.addEventListener('click', () => {
      dialog.close();
    });
  }

  // 2. モーダルの外側（暗い背景）をクリックした時も閉じるようにする
  if (dialog) {
    dialog.addEventListener('click', (event) => {
      // クリックした要素がdialog自身（＝背景部分）だったら閉じる
      if (event.target === dialog) {
        dialog.close();
      }
    });
  }
</script>